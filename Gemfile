source "https://rubygems.org"

# Jekyll 是静态站点生成器，负责把 Markdown、Liquid 模板和 Sass 构建成 HTML/CSS。
gem "jekyll", ">= 3.7", "< 5.0"
# Minimal Mistakes 是当前博客主题，提供布局、归档、导航、搜索等基础能力。
gem "minimal-mistakes-jekyll"
# 分页、站点地图、订阅源和 include 缓存是主题与博客功能依赖的常用插件。
gem "jekyll-paginate", "~> 1.1"
gem "jekyll-sitemap", "~> 1.3"
gem "jekyll-feed", "~> 0.1"
gem "jekyll-include-cache", "~> 0.1"
# Windows/Ruby 环境下的时区数据依赖，保证本地和 CI 构建时日期处理稳定。
gem "tzinfo", "~> 2.0"
gem "tzinfo-data"
